{
  "name": "v8-mapselect-smoke",
  "description": "Select the grand prix map from the start menu, then drive through the spline track.",
  "steps": [
    { "type": "wait_for_selector", "selector": "#map-menu .map-option[data-map='grandprix']" },
    { "type": "click", "selector": "#map-menu .map-option[data-map='grandprix']", "expectNavigation": true, "navigationWaitMs": 1000 },
    { "type": "wait", "ms": 1000, "label": "settle" },
    { "type": "hold", "keys": ["KeyW"], "ms": 2200, "label": "launch straight" },
    { "type": "hold", "keys": ["KeyW", "KeyD"], "ms": 1600, "label": "first bend" },
    { "type": "hold", "keys": ["KeyW"], "ms": 1200, "label": "stabilize" },
    { "type": "hold", "keys": ["KeyW", "KeyA"], "ms": 2000, "label": "sweep left" },
    { "type": "wait", "ms": 800, "label": "cooldown" }
  ]
}
